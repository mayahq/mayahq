{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "target": "es2019",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "composite": true
  },
  "references": [
    { "path": "../supabase-client" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
} 