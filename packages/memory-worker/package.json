    "@langchain/core": "^0.3.12",
    "@langchain/openai": "^0.2.0",
    "@mayahq/supabase-client": "*",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@supabase/supabase-js": "^2.46.1",
    "axios": "^1.6.0",
    "node-html-parser": "^6.1.13",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "langchain": "^0.2.0",
    "limiter": "^2.1.0",
    "node-cron": "^4.2.1",
