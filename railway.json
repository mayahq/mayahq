{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "yarn install && yarn workspace @mayahq/memory-worker build"
  },
  "deploy": {
    "startCommand": "yarn workspace @mayahq/memory-worker start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}