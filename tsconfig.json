{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@mayahq/supabase-client": [
        "packages/supabase-client/src"
      ],
      "@mayahq/supabase-client/*": [
        "packages/supabase-client/src/*"
      ],
      "@mayahq/chat-sdk": [
        "packages/chat-sdk/src"
      ],
      "@mayahq/chat-sdk/*": [
        "packages/chat-sdk/src/*"
      ],
      "@mayahq/memory-worker": [
        "packages/memory-worker/src"
      ],
      "@mayahq/memory-worker/*": [
        "packages/memory-worker/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts"
  ]
}
